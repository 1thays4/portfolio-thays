{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio-thays",
  "compatibility_date": "2026-06-15",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": ["node_modules", "package-lock.json", ".gitignore", "wrangler.jsonc", "README.md"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
